{
  "name": "cif-digitisation-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api": "uv run --project .. python -m uvicorn backend.app:app --host 0.0.0.0 --port 8787 --reload --access-log",
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "uv run --project .. python -m backend.main",
    "dev:all": "node scripts/dev-all.mjs",
